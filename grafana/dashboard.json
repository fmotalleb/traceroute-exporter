    "panel-7": {
      "kind": "Panel",
      "spec": {
        "id": 7,
        "title": "Traceroute topology by address",
        "description": "Edge-only directed topology. Grafana derives every node from source/target, preventing missing-node/nodeRadius failures. Edges with empty endpoint addresses are excluded. If Prometheus renamed the exporter target label to exported_target because of a scrape-label collision, the query restores it to target.",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "refId": "edges",
                  "query": {
                    "kind": "DataQuery",
                    "group": "prometheus",
                    "version": "v0",
                    "datasource": {
                      "name": "${DS_PROMETHEUS}"
                    },
                    "spec": {
                      "editorMode": "code",
                      "exemplar": false,
                      "expr": "(\n  label_replace(\n    max by (id, source, exported_target) (\n      traceroute_edge_info{source!=\"exporter\",parent_address!=\"\",target_address!=\"\",exported_target=~\".+\",job=~\"${job}\",instance=~\"${instance}\"}\n    ),\n    \"target\", \"$1\", \"exported_target\", \"(.+)\"\n  )\n)\nor\n(\n  max by (id, source, target) (\n    traceroute_edge_info{source!=\"exporter\",parent_address!=\"\",target_address!=\"\",exported_target!~\".+\",job=~\"${job}\",instance=~\"${instance}\"}\n  )\n)",
                      "format": "table",
                      "instant": true,
                      "legendFormat": "edges",
                      "range": false,
                      "refId": "edges"
                    }
                  }
                }
              }
            ],
            "transformations": [],
            "queryOptions": {}
          }
        },
        "vizConfig": {
          "kind": "VizConfig",
          "group": "nodeGraph",
          "version": "13.0.0",
          "spec": {
            "options": {
              "nodes": {
                "mainStatUnit": "none",
                "secondaryStatUnit": "none",
                "arcs": []
              },
              "edges": {
                "mainStatUnit": "none",
                "secondaryStatUnit": "none"
              },
              "zoomMode": "cooperative"
            },
            "fieldConfig": {
              "defaults": {},
              "overrides": []
            }
          }
        }
      }
    },
