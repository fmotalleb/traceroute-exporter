{
  "annotations": [],
  "cursorSync": "Tooltip",
  "description": "Traceroute topology and probe health. Shared nodes and edges are deduplicated by address so selecting multiple destinations produces a branching tree/graph.",
  "editable": true,
  "elements": {
    "panel-1": {
      "kind": "Panel",
      "spec": {
        "id": 1,
        "title": "Destination reached",
        "description": "Minimum final-destination success across all selected traceroutes.",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "refId": "A",
                  "query": {
                    "kind": "DataQuery",
                    "group": "prometheus",
                    "version": "v0",
                    "datasource": {
                      "name": "${DS_PROMETHEUS}"
                    },
                    "spec": {
                      "editorMode": "code",
                      "expr": "min(traceroute_probe_success{job=~\"${job}\",instance=~\"${instance}\"} and on(job, instance) traceroute_target_info{job=~\"${job}\",instance=~\"${instance}\",hostname=~\"${hostname}\",resolved_address=~\"${resolved_address}\",address=~\"${destination_address}\",port=~\"${port}\"})",
                      "instant": true,
                      "legendFormat": "Probe success",
                      "range": false,
                      "refId": "A"
                    }
                  }
                }
              }
            ],
            "transformations": [],
            "queryOptions": {}
          }
        },
        "vizConfig": {
          "kind": "VizConfig",
          "group": "stat",
          "version": "13.0.0",
          "spec": {
            "options": {
              "colorMode": "background",
              "graphMode": "none",
              "justifyMode": "auto",
              "orientation": "auto",
              "reduceOptions": {
                "calcs": [
                  "lastNotNull"
                ],
                "fields": "",
                "values": false
              },
              "showPercentChange": false,
              "textMode": "auto",
              "wideLayout": true
            },
            "fieldConfig": {
              "defaults": {
                "color": {
                  "mode": "thresholds"
                },
                "mappings": [
                  {
                    "options": {
                      "0": {
                        "color": "red",
                        "index": 0,
                        "text": "NOT REACHED"
                      },
                      "1": {
                        "color": "green",
                        "index": 1,
                        "text": "REACHED"
                      }
                    },
                    "type": "value"
                  }
                ],
                "unit": "none"
              },
              "overrides": []
            }
          }
        }
      }
    },
