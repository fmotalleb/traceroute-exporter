{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Traceroute exporter dashboard with a Grafana Node Graph tree that can render multiple traceroutes at the same time. Uses traceroute_grafana_node_info and traceroute_grafana_edge_info.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Multi-traceroute tree graph. Select one or more traces in the variables. Node ids are trace-scoped by the exporter, so no-reply hops and duplicate private hops from different traces do not collide.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 18,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "edges": {
          "arrows": true,
          "mainStatUnit": "none",
          "secondaryStatUnit": "none"
        },
        "nodes": {
          "mainStatUnit": "none",
          "secondaryStatUnit": "none"
        }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "traceroute_grafana_node_info{job=~\"${job:regex}\", trace=~\"${trace:regex}\", method=~\"${method:regex}\"}",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "nodes",
          "range": false,
          "refId": "nodes"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "label_replace(traceroute_grafana_edge_info{job=~\"${job:regex}\", trace=~\"${trace:regex}\", method=~\"${method:regex}\"}, \"target\", \"$1\", \"graph_target\", \"(.*)\")",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "edges",
          "range": false,
          "refId": "edges"
        }
      ],
      "title": "Traceroute tree graph - multiple traceroutes",
      "type": "nodeGraph"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Number of selected trace labels currently visible in the graph.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 18
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "count(count by (trace) (traceroute_grafana_edge_info{job=~\"${job:regex}\", trace=~\"${trace:regex}\", method=~\"${method:regex}\"}))",
          "format": "time_series",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Selected traceroutes",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Number of selected graph nodes, including synthetic no-reply nodes.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 18
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "count(traceroute_grafana_node_info{job=~\"${job:regex}\", trace=~\"${trace:regex}\", method=~\"${method:regex}\"})",
          "format": "time_series",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Graph nodes",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Number of no-reply graph nodes in selected traceroutes.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 18
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "count(traceroute_grafana_node_info{job=~\"${job:regex}\", trace=~\"${trace:regex}\", method=~\"${method:regex}\", responded=\"false\"})",
          "format": "time_series",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "No-reply nodes",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Number of traces that reached the loop give-up threshold. Uses the original Prometheus target label; this works when trace values match the target relabel value.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 18
      },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(traceroute_loop_giveup{job=~\"${job:regex}\", target=~\"${trace:regex}\", method=~\"${method:regex}\"})",
          "format": "time_series",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Loop give-ups",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Trace status table. The graph uses trace-scoped ids; this table keeps the human-readable trace label.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "traceroute_grafana_node_info{job=~\"${job:regex}\", trace=~\"${trace:regex}\", method=~\"${method:regex}\", role=\"source\"}",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Selected traces",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "id": true,
              "node": true,
              "title": true,
              "subTitle": true,
              "mainStat": true,
              "secondaryStat": true,
              "detail__trace": true,
              "detail__node": true,
              "detail__hostname": true,
              "detail__address": true,
              "detail__hop": true,
              "detail__responded": true,
              "detail__role": true,
              "instance": true
            },
            "indexByName": {
              "trace": 0,
              "job": 1,
              "method": 2,
              "target_host": 3,
              "target_port": 4,
              "loop_max_repeats": 5,
              "responded": 6,
              "role": 7
            },
            "renameByName": {
              "trace": "trace",
              "target_host": "target host",
              "target_port": "target port",
              "loop_max_repeats": "loop repeats"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
