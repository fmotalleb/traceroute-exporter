# Prometheus exporter-toolkit compatible web config.
# Start with: ./traceroute-exporter --web.config.file=web.yml
# or place web.yml next to the binary and it will be picked up automatically.

# Optional TLS listener configuration. When cert_file and key_file are set,
# the exporter serves HTTPS on --web.listen-address.
# tls_server_config:
#   cert_file: /etc/traceroute-exporter/server.crt
#   key_file: /etc/traceroute-exporter/server.key
#   min_version: TLS12
#   max_version: TLS13
#   # For mutual TLS:
#   # client_ca_file: /etc/traceroute-exporter/client-ca.crt
#   # client_auth_type: RequireAndVerifyClientCert

http_server_config:
  http2: true
  # Optional response headers.
  # headers:
  #   X-Content-Type-Options: nosniff

# Optional HTTP basic auth. Passwords must be bcrypt hashes, same as node_exporter.
# Generate a hash, for example:
#   htpasswd -nBC 10 "" | tr -d ':\n'
# basic_auth_users:
#   prometheus: $2y$10$replace_with_bcrypt_hash
